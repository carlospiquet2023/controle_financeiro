# Gere uma chave forte: openssl rand -base64 32
DATABASE_URL="postgresql://finora:troque-esta-senha@db:5432/finora?schema=public"
AUTH_SECRET="troque-por-uma-chave-com-no-minimo-32-caracteres"
APP_URL="http://localhost:3000"
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"

# Cloudflare R2 (opcional; necessário para comprovantes em produção)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="finora-receipts"
R2_PUBLIC_URL=""

# Open Finance via Pluggy (opcional; produto comercial)
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""
# Defina o mesmo valor como cabeçalho x-finora-webhook-secret no webhook da Pluggy.
PLUGGY_WEBHOOK_SECRET=""

# OCR via Google Document AI (opcional; requer processador e credenciais Google)
GOOGLE_CLOUD_PROJECT=""
GOOGLE_DOCUMENT_AI_LOCATION="us"
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=""
# Use GOOGLE_APPLICATION_CREDENTIALS no ambiente quando não houver identidade de workload.
GOOGLE_APPLICATION_CREDENTIALS=""
